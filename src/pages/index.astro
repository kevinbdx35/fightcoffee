---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Adn from '../components/sections/Adn.astro';
import Structure from '../components/sections/Structure.astro';
import Disciplines from '../components/sections/Disciplines.astro';
import Lifestyle from '../components/sections/Lifestyle.astro';
import LocalFit from '../components/sections/LocalFit.astro';
import Concurrence from '../components/sections/Concurrence.astro';
import Problem from '../components/sections/Problem.astro';
import Diff from '../components/sections/Diff.astro';
import Benchmarks from '../components/sections/Benchmarks.astro';
import Kids from '../components/sections/Kids.astro';
import BusinessModel from '../components/sections/BusinessModel.astro';
import Offre from '../components/sections/Offre.astro';
import Roadmap from '../components/sections/Roadmap.astro';
import Conformite from '../components/sections/Conformite.astro';
import Finances from '../components/sections/Finances.astro';
import Invest from '../components/sections/Invest.astro';
import Vision from '../components/sections/Vision.astro';
import Team from '../components/sections/Team.astro';
import Ask from '../components/sections/Ask.astro';
---

<Layout title="FightCoffee — Deck Investisseur">

<Nav />
<Hero />
<Adn />
<Structure />
<Disciplines />
<Lifestyle />
<LocalFit />
<Concurrence />
<Problem />
<Diff />
<Benchmarks />
<Kids />
<BusinessModel />
<Offre />
<Roadmap />
<Conformite />
<Finances />
<Invest />
<Vision />
<Team />
<Ask />
<Footer />

<!-- ── Navigateur de slides ── -->
<div class="slide-nav" role="navigation" aria-label="Navigation entre sections">
  <button class="slide-nav-btn" id="slide-prev" aria-label="Section précédente">
    <svg width="22" height="22" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="12,10 8,6 4,10"/></svg>
  </button>
  <div class="nav-dots" id="nav-dots"></div>
  <button class="slide-nav-btn" id="slide-next" aria-label="Section suivante">
    <svg width="22" height="22" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,6 8,10 12,6"/></svg>
  </button>
</div>

<script>
  // ── Hamburger ──
  const toggle = document.querySelector('.nav-toggle');
  const navLinks = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    const open = navLinks?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });
  // Close on link click (mobile)
  navLinks?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => navLinks.classList.remove('open'));
  });

  // ── Nav shadow on scroll ──
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  // ── Scroll animations ──
  const slideObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('slide-visible');
        slideObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.slide').forEach(s => slideObserver.observe(s));

  // ── Progress bar ──
  const progressBar = document.createElement('div');
  progressBar.id = 'nav-progress';
  document.querySelector('nav')?.appendChild(progressBar);
  window.addEventListener('scroll', () => {
    const total = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.width = total > 0 ? (window.scrollY / total * 100) + '%' : '0%';
  }, { passive: true });

  // ── Slide navigator ──
  const allSections = Array.from(document.querySelectorAll('section[id]'));
  const btnPrev = document.getElementById('slide-prev') as HTMLButtonElement | null;
  const btnNext = document.getElementById('slide-next') as HTMLButtonElement | null;
  const dotsContainer = document.getElementById('nav-dots');
  let currentIdx = 0;

  // Build section title map from nav links
  const sectionTitles: Record<string, string> = {};
  document.querySelectorAll('.nav-links a').forEach(a => {
    const id = a.getAttribute('href')?.replace('#', '');
    if (id) sectionTitles[id] = (a as HTMLElement).textContent?.trim() || id;
  });

  // Create dots
  const dots: HTMLButtonElement[] = [];
  allSections.forEach((sec, i) => {
    const dot = document.createElement('button');
    dot.className = 'nav-dot';
    dot.setAttribute('aria-label', sectionTitles[sec.id] || sec.id);
    dot.title = sectionTitles[sec.id] || sec.id;
    dot.addEventListener('click', () => goTo(i));
    dotsContainer?.appendChild(dot);
    dots.push(dot);
  });

  function updateNav() {
    if (!btnPrev || !btnNext) return;
    btnPrev.disabled = currentIdx === 0;
    btnNext.disabled = currentIdx === allSections.length - 1;
    dots.forEach((d, i) => d.classList.toggle('active', i === currentIdx));
  }

  function goTo(idx: number) {
    if (idx < 0 || idx >= allSections.length) return;
    currentIdx = idx;
    allSections[currentIdx].scrollIntoView({ behavior: 'smooth' });
    updateNav();
  }

  btnPrev?.addEventListener('click', () => goTo(currentIdx - 1));
  btnNext?.addEventListener('click', () => goTo(currentIdx + 1));

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowDown' || e.key === 'PageDown') { e.preventDefault(); goTo(currentIdx + 1); }
    if (e.key === 'ArrowUp' || e.key === 'PageUp') { e.preventDefault(); goTo(currentIdx - 1); }
  });

  // Sync index with scroll position
  const slideNavObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = allSections.indexOf(e.target as HTMLElement);
        if (idx !== -1) { currentIdx = idx; updateNav(); }
      }
    });
  }, { threshold: 0.4 });
  allSections.forEach(s => slideNavObserver.observe(s));

  updateNav();

  // ── Active nav link ──
  const sections = document.querySelectorAll('section[id]');
  const links = document.querySelectorAll('.nav-links a');
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        const active = document.querySelector(`.nav-links a[href="#${e.target.id}"]`);
        active?.classList.add('active');
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  sections.forEach(s => navObserver.observe(s));
</script>

</Layout>
