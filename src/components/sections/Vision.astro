<!-- ═══ 10 VISION ═══ -->
<section class="slide" id="vision" style="background:var(--ink); padding-bottom:0;">
  <!-- Header -->
  <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:48px;">
    <div>
      <div class="eyebrow" style="color:var(--ink3);">10 — Vision long terme</div>
      <div style="font-family:var(--display); font-size:clamp(56px, 9vw, 124px); line-height:0.88; letter-spacing:4px; color:#f8f6f2;">
        UNE <span style="color:var(--red);">MARQUE.</span><br>PAS UN LIEU.
      </div>
    </div>
    <div style="text-align:right; padding-top:8px;">
      <p style="font-size:15px; color:#9a9490; line-height:1.8; font-weight:300; max-width:320px;">Ce qu'on construit ici, c'est un réseau de lieux hybrides avec une marque forte et une communauté nationale.</p>
    </div>
  </div>

  <!-- Image plein cadre -->
  <div style="height:320px; margin:0 -80px; overflow:hidden; position:relative;">
    <img
      src="/fightcoffee/images/facade.webp"
      alt="Façade FightCoffee Hybrid Combat Sports"
      style="width:100%; height:100%; object-fit:cover; filter:brightness(0.55);"
    />
    <div style="position:absolute; inset:0; background:linear-gradient(to right, rgba(24,22,20,0.75) 0%, transparent 40%, transparent 60%, rgba(24,22,20,0.75) 100%);"></div>
    <!-- Villes -->
    <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:space-around; padding:0 60px;">
      <div style="text-align:center;">
        <div style="font-family:var(--display); font-size:clamp(20px,3vw,36px); letter-spacing:4px; color:#f8f6f2;">PLEURTUIT</div>
        <div style="font-family:var(--mono); font-size:9px; letter-spacing:2px; color:var(--red); text-transform:uppercase; margin-top:6px;">Phase 1 · Pilote</div>
      </div>
      <div style="width:1px; height:48px; background:rgba(255,255,255,0.15);"></div>
      <div style="text-align:center; opacity:0.5;">
        <div style="font-family:var(--display); font-size:clamp(20px,3vw,36px); letter-spacing:4px; color:#f8f6f2;">SAINT-MALO</div>
        <div style="font-family:var(--mono); font-size:9px; letter-spacing:2px; color:#9a9490; text-transform:uppercase; margin-top:6px;">Phase 2 · 1ère duplication</div>
      </div>
      <div style="width:1px; height:48px; background:rgba(255,255,255,0.15);"></div>
      <div style="text-align:center; opacity:0.35;">
        <div style="font-family:var(--display); font-size:clamp(20px,3vw,36px); letter-spacing:4px; color:#f8f6f2;">DINARD</div>
        <div style="font-family:var(--mono); font-size:9px; letter-spacing:2px; color:#9a9490; text-transform:uppercase; margin-top:6px;">Phase 2 · 2ème duplication</div>
      </div>
      <div style="width:1px; height:48px; background:rgba(255,255,255,0.15);"></div>
      <div style="text-align:center; opacity:0.2;">
        <div style="font-family:var(--display); font-size:clamp(20px,3vw,36px); letter-spacing:4px; color:#f8f6f2;">FRANCE</div>
        <div style="font-family:var(--mono); font-size:9px; letter-spacing:2px; color:#9a9490; text-transform:uppercase; margin-top:6px;">Phase 3 · Réseau national</div>
      </div>
    </div>
  </div>

  <!-- 4 étapes en grille -->
  <div style="display:grid; grid-template-columns:repeat(4,1fr); margin:0 -80px;">
    <div style="padding:36px 32px; border-right:1px solid rgba(255,255,255,0.07); position:relative; overflow:hidden;">
      <div style="font-family:var(--display); font-size:100px; line-height:1; color:rgba(255,255,255,0.04); position:absolute; right:12px; top:8px; pointer-events:none;">1</div>
      <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--red); text-transform:uppercase; margin-bottom:16px;">Fighter in Residence</div>
      <div style="font-family:var(--display); font-size:22px; letter-spacing:2px; color:#f8f6f2; margin-bottom:12px;">RÉSIDENCES</div>
      <p style="font-size:13px; color:#9a9490; line-height:1.7;">Chaque résidence est un événement. Contenu, membres, notoriété.</p>
    </div>
    <div style="padding:36px 32px; border-right:1px solid rgba(255,255,255,0.07); position:relative; overflow:hidden;">
      <div style="font-family:var(--display); font-size:100px; line-height:1; color:rgba(255,255,255,0.04); position:absolute; right:12px; top:8px; pointer-events:none;">2</div>
      <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--gold); text-transform:uppercase; margin-bottom:16px;">Fight nights · UFC · ADCC</div>
      <div style="font-family:var(--display); font-size:22px; letter-spacing:2px; color:#f8f6f2; margin-bottom:12px;">ÉVÉNEMENTS</div>
      <p style="font-size:13px; color:#9a9490; line-height:1.7;">Le calendrier crée fidélité et visibilité au-delà du bassin local.</p>
    </div>
    <div style="padding:36px 32px; border-right:1px solid rgba(255,255,255,0.07); position:relative; overflow:hidden;">
      <div style="font-family:var(--display); font-size:100px; line-height:1; color:rgba(255,255,255,0.04); position:absolute; right:12px; top:8px; pointer-events:none;">3</div>
      <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--ink3); text-transform:uppercase; margin-bottom:16px;">Merch · Contenu · Communauté</div>
      <div style="font-family:var(--display); font-size:22px; letter-spacing:2px; color:#f8f6f2; margin-bottom:12px;">MARQUE</div>
      <p style="font-size:13px; color:#9a9490; line-height:1.7;">FightCoffee dépasse le lieu physique — c'est un univers en ligne.</p>
    </div>
    <div style="padding:36px 32px; position:relative; overflow:hidden;">
      <div style="font-family:var(--display); font-size:100px; line-height:1; color:rgba(255,255,255,0.04); position:absolute; right:12px; top:8px; pointer-events:none;">4</div>
      <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--ink3); text-transform:uppercase; margin-bottom:16px;">Franchise · Licensing</div>
      <div style="font-family:var(--display); font-size:22px; letter-spacing:2px; color:#f8f6f2; margin-bottom:12px;">RÉSEAU</div>
      <p style="font-size:13px; color:#9a9490; line-height:1.7;">Duplication dans d'autres villes côtières et urbaines. Ownership ou franchise.</p>
    </div>
  </div>
</section>
