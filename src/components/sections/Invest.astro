<!-- ═══ 09b INVESTISSEMENT ═══ -->
<section class="slide alt" id="invest">
  <div class="eyebrow red">09b — Investissement</div>
  <div class="display lg mb24">OÙ VA L'ARGENT.</div>
  <div style="display:grid; grid-template-columns:1.4fr 1fr; gap:48px; align-items:start;">
    <div>
      <div style="border:1px solid var(--rule);">
        <div style="display:grid; grid-template-columns:1fr auto auto; background:var(--ink); padding:10px 18px; gap:16px;">
          <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:#f8f6f2; text-transform:uppercase;">Poste</div>
          <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--gold); text-transform:uppercase; text-align:center; min-width:48px;">%</div>
          <div style="font-family:var(--mono); font-size:10px; letter-spacing:2px; color:#f8f6f2; text-transform:uppercase; text-align:right; min-width:160px;">Fourchette</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); background:var(--red-pale); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Aménagement & travaux</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--red); font-weight:600; text-align:center; min-width:48px;">30%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">55 000 – 75 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Équipements combat (ring, sacs, tatamis)</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--red); font-weight:600; text-align:center; min-width:48px;">25%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">45 000 – 60 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); background:var(--gold-pale); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Mobilier & équipement coffee shop</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--gold); font-weight:600; text-align:center; min-width:48px;">10%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">18 000 – 25 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Fonds de roulement (3 mois de charges)</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--ink3); font-weight:600; text-align:center; min-width:48px;">20%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">36 000 – 55 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Marketing & pré-lancement</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--ink3); font-weight:600; text-align:center; min-width:48px;">7%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">12 000 – 18 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; border-bottom:1px solid var(--rule); gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Systèmes (POS, logiciel salle, sécurité)</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--ink3); font-weight:600; text-align:center; min-width:48px;">5%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">8 000 – 12 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:11px 18px; gap:16px; align-items:center;">
          <div style="font-size:13px; color:var(--ink);">Frais juridiques, comptabilité, divers</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--ink3); font-weight:600; text-align:center; min-width:48px;">3%</div>
          <div style="font-size:13px; color:var(--ink2); text-align:right; min-width:160px;">5 000 – 8 000 €</div>
        </div>
        <div style="display:grid; grid-template-columns:1fr auto auto; padding:14px 18px; background:var(--ink); gap:16px; align-items:center; border-top:1px solid var(--rule);">
          <div style="font-family:var(--display); font-size:16px; letter-spacing:2px; color:#f8f6f2;">TOTAL</div>
          <div style="font-family:var(--mono); font-size:12px; color:var(--gold); font-weight:600; text-align:center; min-width:48px;">100%</div>
          <div style="font-family:var(--display); font-size:20px; color:var(--red); text-align:right; min-width:160px;">179 – 253 k€</div>
        </div>
      </div>
    </div>
    <div style="display:flex; flex-direction:column; gap:16px;">
      <div style="border:1px solid var(--rule); padding:20px 24px; background:var(--white);">
        <div class="cell-label mb12">Charges fixes mensuelles</div>
        <div style="font-family:var(--display); font-size:36px; color:var(--ink); margin-bottom:4px;">17–25k€</div>
        <p style="font-size:12px; color:var(--ink3); line-height:1.7;">Loyer (5–7k€) · Masse salariale (8–11k€) · Appro coffee · Assurances, logiciels, énergie.</p>
      </div>
      <div style="border:1px solid var(--rule); padding:20px 24px; background:var(--gold-pale);">
        <div class="cell-label gold mb12">Pistes de financement</div>
        <ul class="dot-list">
          <li><strong>Apport propres</strong> — 30–40% minimum recommandé</li>
          <li><strong>Emprunt bancaire</strong> — 5–7 ans, taux 4,5–6%</li>
          <li><strong>ACRE</strong> — exonération charges An 1</li>
          <li><strong>Prêt d'honneur</strong> — Réseau Entreprendre / Initiative</li>
          <li><strong>Aides Région Bretagne</strong> — tourisme sportif & innovation</li>
        </ul>
      </div>
      <div style="padding:14px 16px; border-left:3px solid var(--red); background:var(--red-pale); font-size:12px; color:var(--ink2); line-height:1.75;">
        <strong style="color:var(--ink);">Note :</strong> le fonds de roulement (20% du budget) est critique. Il couvre les 3 premiers mois de charges pendant la montée en charge.
      </div>
    </div>
  </div>
</section>
